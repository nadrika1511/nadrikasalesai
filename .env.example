# Firebase (estos SÍ son públicos, Firebase los expone al cliente por diseño)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# NUNCA pongas aquí el OpenAI API Key ni el WhatsApp Token.
# Esos van como Secrets de Cloud Functions (firebase functions:secrets:set)
# y jamás deben viajar al frontend.
